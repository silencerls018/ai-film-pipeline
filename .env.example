# OpenAI-compatible API (optional for dry-run mode)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Set to 1 to skip live LLM calls and use offline stubs
FILM_PIPELINE_DRY_RUN=1

# Live mode: set 1 to allow explicit stub fallback on LLM failure (default off — no silent stub)
# FILM_PIPELINE_STUB_FALLBACK=0

# Daily knowledge upgrade on first run (1=on). Skip network: FILM_PIPELINE_SKIP_KNOWLEDGE_UPDATE=1
# FILM_PIPELINE_DAILY_KNOWLEDGE=1
