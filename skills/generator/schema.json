{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeneratorOutput",
  "type": "object",
  "required": ["generation_jobs"],
  "additionalProperties": false,
  "properties": {
    "generation_jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["shot_id", "visual_prompt", "motion_prompt"],
        "properties": {
          "shot_id": { "type": "string" },
          "clip_id": { "type": "string" },
          "scene_id": { "type": "string" },
          "visual_prompt": { "type": "string" },
          "motion_prompt": { "type": "string" },
          "master_prompt": { "type": "string" },
          "actor_free_prompt": { "type": "string" },
          "director_guided_prompt": { "type": "string" },
          "actor_free_prompt_zh": { "type": "string" },
          "director_guided_prompt_zh": { "type": "string" },
          "actor_free_prompt_en": { "type": "string" },
          "director_guided_prompt_en": { "type": "string" },
          "negative_prompt": { "type": "string" },
          "zh_director_summary": { "type": "string" },
          "duration_sec": { "type": "number" },
          "timeline_start_sec": { "type": "number" },
          "timeline_end_sec": { "type": "number" },
          "stitch": { "type": "string" },
          "extend_from_clip": { "type": ["string", "null"] },
          "sources": { "type": "object" },
          "downgrades": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
