{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DramaturgOutput",
  "type": "object",
  "required": ["story", "characters", "scenes"],
  "additionalProperties": false,
  "properties": {
    "story": {
      "type": "object",
      "required": ["logline", "theme"],
      "properties": {
        "logline": { "type": "string" },
        "theme": { "type": "string" },
        "acts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "summary": { "type": "string" }
            },
            "required": ["name", "summary"]
          }
        }
      }
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "want": { "type": "string" },
          "need": { "type": "string" },
          "arc": { "type": "string" },
          "voice": { "type": "string" }
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "setting", "dramatic_function", "emotion"],
        "properties": {
          "scene_id": { "type": "string" },
          "setting": { "type": "string" },
          "summary": { "type": "string" },
          "dramatic_function": { "type": "string" },
          "emotion": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" },
              "peak": { "type": "number" },
              "primary": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
